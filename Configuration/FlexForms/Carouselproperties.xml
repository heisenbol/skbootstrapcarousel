
<T3DataStructure>

	 <meta type="array">
		 <langChildren>0</langChildren>
		 <langDisable>1</langDisable>
	 </meta>
	 <sheets>
		 <sDEF>
			 <ROOT>
                <sheetTitle>Texts</sheetTitle>
			 	<type>array</type>
				 <el>
					<settings.displaymode>
						<label>Display Mode</label>
						<onChange>reload</onChange>
						<config>
							<type>select</type>
							<renderType>selectSingle</renderType>
							<items type="array">
								<numIndex index="0" type="array">
									<label>Carousel</label>
									<value>carousel</value>
								</numIndex>
								<numIndex index="1" type="array">
									<label>Lightbox (no text)</label>
									<value>lightbox</value>
								</numIndex>
								<numIndex index="2" type="array">
									<label>Columns</label>
									<value>columns</value>
								</numIndex>
							</items>
							<maxitems>1</maxitems>
							<size>1</size>
						</config>
					</settings.displaymode>

					<settings.groupsof>
						<label>Lightbox grouping</label>
						<displayCond><![CDATA[FIELD:settings.displaymode:=:lightbox]]></displayCond>
						<config>
							<type>select</type>
							<renderType>selectSingle</renderType>
							<items type="array">
								<numIndex index="0" type="array">
									<label>8</label>
									<value>8</value>
								</numIndex>
								<numIndex index="1" type="array">
									<label>6</label>
									<value>6</value>
								</numIndex>
								<numIndex index="2" type="array">
									<label>4</label>
									<value>4</value>
								</numIndex>
							</items>
							<maxitems>1</maxitems>
							<size>1</size>
						</config>
					</settings.groupsof>

					<settings.columns>
						<label>Columns</label>
						<displayCond><![CDATA[FIELD:settings.displaymode:=:columns]]></displayCond>
						<config>
							<type>select</type>
							<renderType>selectSingle</renderType>
							<items type="array">
								<numIndex index="0" type="array">
									<label>6</label>
									<value>6</value>
								</numIndex>
								<numIndex index="1" type="array">
									<label>4</label>
									<value>4</value>
								</numIndex>
								<numIndex index="2" type="array">
									<label>3</label>
									<value>3</value>
								</numIndex>
								<numIndex index="3" type="array">
									<label>2</label>
									<value>2</value>
								</numIndex>
							</items>
							<maxitems>1</maxitems>
							<size>1</size>
						</config>
					</settings.columns>

					<settings.waittime>
						<label>Pause time (ms)</label>
						<config>
							<type>number</type>
							<size>6</size>
							<range>
								<lower>500</lower>
							</range>
							<default>5000</default>
						</config>
					</settings.waittime>

					<settings.autoplay>
						<label>Auto play</label>
						<config>
							<type>check</type>
							<default>1</default>
						</config>
					</settings.autoplay>

					<settings.nextprev>
						<label>Show next / previous</label>
						<displayCond><![CDATA[FIELD:settings.displaymode:=:carousel]]></displayCond>
						<config>
							<type>check</type>
							<default>1</default>
						</config>
					</settings.nextprev>

					<settings.showbullets>
						<label>Show indicators</label>
						<config>
							<type>select</type>
							<renderType>selectSingle</renderType>
							<items type="array">
								<numIndex index="0" type="array">
									<label>Do not show</label>
									<value>0</value>
								</numIndex>
								<numIndex index="1" type="array">
									<label>Within slides</label>
									<value>1</value>
								</numIndex>
								<numIndex index="2" type="array">
									<label>Above slides</label>
									<value>2</value>
								</numIndex>
								<numIndex index="3" type="array">
									<label>Below slides</label>
									<value>3</value>
								</numIndex>
							</items>
							<maxitems>1</maxitems>
							<size>1</size>
						</config>
					</settings.showbullets>

					<settings.transitionfade>
						<label>Transition fade</label>
						<config>
							<type>check</type>
							<default>1</default>
						</config>
					</settings.transitionfade>

					<settings.width>
						<label>Number for Image Width</label>
						<config>
							<type>number</type>
							<size>6</size>
							<default>1600</default>
						</config>
					</settings.width>

					<settings.height>
						<label>Number for Image Height</label>
						<config>
							<type>number</type>
							<size>6</size>
							<default>600</default>
						</config>
					</settings.height>
				 </el>
			 </ROOT>
		</sDEF>

	</sheets>
 </T3DataStructure>
